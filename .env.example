# VidyAI — Environment Variables
# Copy this file to .env and fill in your values

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o                  # Primary model (GPT-4o)
OPENAI_MINI_MODEL=gpt-4o-mini        # Mini model for fast/cheap tasks

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Format: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/vidyai?retryWrites=true&w=majority
# For local dev:
# MONGO_URI=mongodb://localhost:27017

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password          # Use Gmail App Password (not account password)
SMTP_FROM=VidyAI <your-email@gmail.com>

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
# VERCEL=1                           # Auto-set by Vercel platform
