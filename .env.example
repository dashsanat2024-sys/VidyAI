# VidyAI — Environment Variables
# Copy this file to .env and fill in your values

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4o-mini             # Primary model (CHANGED to mini to avoid charges)
OPENAI_MINI_MODEL=gpt-4o-mini        # Mini model for fast/cheap tasks
OPENAI_API_KEY_BULK_PRIMARY=         # Optional: dedicated key for bulk OCR
OPENAI_API_KEY_BULK_FALLBACK=        # Optional: fallback key on 429/quota
OPENAI_API_KEY_PREMIUM=              # Optional: escalation queue key
OCR_VISION_MODEL=gpt-4o-mini
OCR_PREMIUM_VISION_MODEL=gpt-4o-mini
SUBJECTIVE_OCR_MODEL=gpt-4o-mini
OCR_QUALITY_ESCALATION_THRESHOLD=0.75
OCR_MAX_IMAGE_DIM=1024
OCR_JPEG_QUALITY=75
OCR_PREPROCESS_GEOMETRY=1
OCR_PREPROCESS_CLAHE=1
OCR_PREPROCESS_COMPRESSION=1
OCR_FAST_COST=0
MULTI_EVAL_BATCH_SIZE=5
MULTI_EVAL_INTER_BATCH_DELAY=0.75
MULTI_EVAL_EXTRACT_ATTEMPTS=5
MULTI_EVAL_EVAL_ATTEMPTS=4
CELERY_TASK_SOFT_TIME_LIMIT=1800
CELERY_TASK_TIME_LIMIT=2100

# ── Cost-Optimized Evaluation Pipeline ────────────────────────────────────────
# New architecture: OpenCV bubbles → Google Vision OCR → Tiered grading
USE_OPENCV_BUBBLES=1                          # Use OpenCV OMR for bubble detection (98-99% accuracy, near-zero cost)
OPENCV_BUBBLE_CONFIDENCE_THRESHOLD=0.85       # Fallback to Vision API if confidence < 0.85
USE_GOOGLE_VISION_OCR=1                       # ENABLED: Using service account credentials
GOOGLE_CLOUD_PROJECT=arthavi-492410           # GCP project ID for Vision API
GOOGLE_APPLICATION_CREDENTIALS=/Users/sanat/Education/AI_Education/google-vision-key.json  # Path to service account key file
PDF_DPI=300                                   # MAX resolution for perfect OMR
OCR_PDF_DPI=300                               # MAX resolution for perfect Handwriting OCR
GRADING_TIER_SYSTEM=1                         # Enable mini→premium escalation
GRADING_MINI_MODEL=gpt-4o-mini                # Standard grading model (cheap)
GRADING_PREMIUM_MODEL=gpt-4o-mini             # Premium grading model (CHANGED to mini to avoid charges)
GRADING_CONFIDENCE_ESCALATION=0.75            # Escalate to premium if confidence < 0.75

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Docker Compose (services talk to hostname `mongo`):
# MONGO_URI=mongodb://mongo:27017
# App on host + DB in Docker (port mapped):
MONGO_URI=mongodb://localhost:27017
# Atlas (TLS applied automatically for mongodb+srv / tls=true / ssl=true):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Celery async (optional). Host + Redis in Docker:
REDIS_URL=redis://localhost:6379/0
# Start worker: celery -A celery_worker worker --loglevel=info
# Or: docker compose up -d worker

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dashsanat2024@gmail.com
SMTP_PASS=gcfcpazxldqcqoeq          # Use Gmail App Password (not account password)
SMTP_FROM=Arthavi dashsanat2024@gmail.com

# ── Local LLM (Ollama) — grading subjective answers ───────────────────────────
# Start: ollama serve  (install: https://ollama.ai)
# Pull model: ollama pull qwen2.5:7b
OLLAMA_URL=http://host.docker.internal:11434/api/generate
OLLAMA_MODEL=qwen2.5:7b

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated front-end origins (required for credentialed cross-origin API calls).
# If unset, defaults include https://www.arthavi.in and https://arthavi.in .
# CORS_ORIGINS=https://www.arthavi.in,https://arthavi.in,https://your-app.vercel.app

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
# VERCEL=1                           # Auto-set by Vercel platform
