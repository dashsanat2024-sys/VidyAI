{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/app.py"
    },
    {
      "source": "/",
      "destination": "frontend/index.html"
    },
    {
      "source": "/(manifest.json|sw.js)",
      "destination": "frontend/$1"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.9"
  }
}
